# config.local.yaml — per-instance overrides (gitignored)
#
# Values here are deep-merged over config.yaml.
# Only specify what differs from the defaults.
# Nested objects are merged field-by-field; arrays replace entirely.

# Optional: override the legacy top-level model key for old overlays.
# Pi agents must still set their own explicit `model`; this key is accepted for
# compatibility but is no longer inherited by agents.
# defaultModel: gpt-5.5

# Optional: SOPS-backed runtime secrets. These are only non-secret pointers to
# private deployment artifacts. Runtime SOPS files are not part of this public
# repo and must not be committed. SOPS key paths are dot paths with
# [A-Za-z0-9_-]+ segments; a configured *SopsKey requires secrets.sopsFile.
# secrets:
#   sopsFile: config/secrets.sops.yaml
# telegramTokenSopsKey: telegram.bot_token
# telegramTokenEnv: TELEGRAM_BOT_TOKEN   # optional environment deployment override

agents:
  main:
    workspaceCwd: /absolute/path/to/agent/workspace   # must be inside the resolved workspace root (~ not expanded)
    model: gpt-5.5
    # provider: pi      # optional compatibility field; omit or set to "pi"
    # thinking: xhigh   # optional Pi/Codex thinking level: off, minimal, low, medium, high, xhigh
                        # Cron execution is Pi print mode; crons use workspaceCwd,
                        # optional systemPrompt, and thinking.

bindings:
  - chatId: 111111111           # placeholder Telegram user ID; replace with your numeric ID
    agentId: main
    kind: dm
    label: My DM

# Optional: global defaults for all bindings (per-binding values override these)
# sessionDefaults:
#   requireMention: true              # require @mention for all group bindings unless overridden

# Optional: default delivery target for cron results
# defaultDeliveryChatId: -1001111111111
# defaultDeliveryThreadId: 42

# Optional: admin chat for fallback notifications when cron delivery fails
# adminChatId: 111111111

# Optional: Discord support
# discord:
#   tokenSopsKey: discord.bot_token
#   tokenEnv: DISCORD_BOT_TOKEN          # optional environment deployment override
#   bindings:
#     - guildId: 'YOUR_GUILD_ID'
#       agentId: main
#       kind: channel
#       requireMention: true
